## Step 3: Add Jenkinsfile

```groovy
pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/yourusername/department-website.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t department-site .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 8081:80 department-site'
            }
        }

        stage('Deploy Kubernetes') {
            steps {
                sh 'kubectl apply -f deployment.yaml'
                sh 'kubectl apply -f service.yaml'
            }
        }
    }
}
```

